{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "image": {
      "type": "object",
      "properties": {
        "registry": { "type": "string" },
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string", "minLength": 1 },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      },
      "required": ["registry", "repository", "tag", "pullPolicy"]
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" },
        "annotations": { "type": "object" }
      }
    },
    "rbac": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" }
      }
    },
    "executionPools": {
      "type": "object",
      "properties": {
        "defaultPool": { "type": "string", "minLength": 1 },
        "pools": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "object",
            "properties": {
              "description": { "type": "string" },
              "nodeSelector": { "type": "object" },
              "tolerations": { "type": "array" },
              "resources": { "type": "object" },
              "timeoutSeconds": { "type": "integer", "minimum": 1 },
              "maxConcurrentJobs": { "type": "integer", "minimum": 1 },
              "ttlSecondsAfterFinished": { "type": "integer", "minimum": 0 },
              "policy": {
                "type": "object",
                "properties": {
                  "images": {
                    "type": "object",
                    "properties": {
                      "allowed": { "type": "array", "items": { "type": "string" } },
                      "requireDigest": { "type": "boolean" }
                    }
                  },
                  "python": {
                    "type": "object",
                    "properties": {
                      "maxDependencies": { "type": "integer", "minimum": 0 },
                      "maxDependencyLength": { "type": "integer", "minimum": 1 },
                      "blockedDependencies": { "type": "array", "items": { "type": "string" } }
                    }
                  }
                }
              },
              "allowedImages": { "type": "array", "items": { "type": "string" } },
              "requireDigestImages": { "type": "boolean" },
              "maxPythonDependencies": { "type": "integer", "minimum": 0 },
              "maxPythonDependencyLength": { "type": "integer", "minimum": 1 },
              "blockedPythonDependencies": { "type": "array", "items": { "type": "string" } }
            },
            "required": ["resources", "timeoutSeconds", "maxConcurrentJobs"]
          }
        }
      },
      "required": ["defaultPool", "pools"]
    },
    "executionNetworkPolicy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "allowDns": { "type": "boolean" },
        "additionalEgress": { "type": "array" }
      },
      "required": ["enabled", "allowDns", "additionalEgress"]
    },
    "postgresql": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["bundled", "external"]
        },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string", "minLength": 1 },
            "tag": { "type": "string", "minLength": 1 },
            "pullPolicy": {
              "type": "string",
              "enum": ["Always", "IfNotPresent", "Never"]
            }
          },
          "required": ["repository", "tag", "pullPolicy"]
        },
        "auth": {
          "type": "object",
          "properties": {
            "database": { "type": "string", "minLength": 1 },
            "username": { "type": "string", "minLength": 1 },
            "password": { "type": "string", "minLength": 1 }
          },
          "required": ["database", "username", "password"]
        },
        "service": {
          "type": "object",
          "properties": {
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
          },
          "required": ["port"]
        },
        "persistence": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "size": { "type": "string", "minLength": 1 },
            "storageClass": { "type": "string" }
          },
          "required": ["enabled", "size"]
        },
        "securityContext": { "type": "object" },
        "containerSecurityContext": { "type": "object" },
        "resources": { "type": "object" }
        ,
        "backup": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "schedule": { "type": "string", "minLength": 1 },
            "retentionDays": { "type": "integer", "minimum": 1 },
            "persistence": {
              "type": "object",
              "properties": {
                "enabled": { "type": "boolean" },
                "size": { "type": "string", "minLength": 1 },
                "storageClass": { "type": "string" }
              },
              "required": ["enabled", "size"]
            },
            "resources": { "type": "object" }
          },
          "required": ["enabled", "schedule", "retentionDays", "persistence"]
        }
      },
      "required": ["mode", "image", "auth", "service", "persistence"]
    },
    "minio": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["bundled", "external"]
        },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string", "minLength": 1 },
            "tag": { "type": "string", "minLength": 1 },
            "pullPolicy": {
              "type": "string",
              "enum": ["Always", "IfNotPresent", "Never"]
            }
          },
          "required": ["repository", "tag", "pullPolicy"]
        },
        "mcImage": {
          "type": "object",
          "properties": {
            "repository": { "type": "string", "minLength": 1 },
            "tag": { "type": "string", "minLength": 1 },
            "pullPolicy": {
              "type": "string",
              "enum": ["Always", "IfNotPresent", "Never"]
            }
          },
          "required": ["repository", "tag", "pullPolicy"]
        },
        "auth": {
          "type": "object",
          "properties": {
            "rootUser": { "type": "string", "minLength": 1 },
            "rootPassword": { "type": "string", "minLength": 8 }
          },
          "required": ["rootUser", "rootPassword"]
        },
        "bucket": { "type": "string", "minLength": 1 },
        "region": { "type": "string", "minLength": 1 },
        "pathStyle": { "type": "boolean" },
        "service": {
          "type": "object",
          "properties": {
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
            "consolePort": { "type": "integer", "minimum": 1, "maximum": 65535 }
          },
          "required": ["port", "consolePort"]
        },
        "persistence": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "size": { "type": "string", "minLength": 1 },
            "storageClass": { "type": "string" }
          },
          "required": ["enabled", "size"]
        },
        "securityContext": { "type": "object" },
        "containerSecurityContext": { "type": "object" },
        "resources": { "type": "object" },
        "bucketJob": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "backoffLimit": { "type": "integer", "minimum": 0 }
          },
          "required": ["enabled", "backoffLimit"]
        }
      },
      "required": ["mode", "image", "mcImage", "auth", "bucket", "region", "pathStyle", "service", "persistence", "bucketJob"]
    },
    "migrations": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "backoffLimit": { "type": "integer", "minimum": 0 }
      },
      "required": ["enabled", "backoffLimit"]
    },
    "api": {
      "type": "object",
      "properties": {
        "auth": {
          "type": "object",
          "properties": {
            "disabled": { "type": "boolean" },
            "existingSecret": { "type": "string", "minLength": 1 },
            "secretKey": { "type": "string", "minLength": 1 }
          },
          "required": ["disabled", "existingSecret", "secretKey"]
        },
        "webhooks": {
          "type": "object",
          "properties": {
            "existingSecret": { "type": "string" },
            "secretKey": { "type": "string", "minLength": 1 }
          },
          "required": ["existingSecret", "secretKey"]
        }
      }
    },
    "worker": {
      "type": "object",
      "properties": {
        "runner": {
          "type": "object",
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["stub", "kubernetes", "k8s"]
            },
            "executionNamespace": { "type": "string" },
            "logLimitBytes": { "type": "integer", "minimum": 1 },
            "loop": { "type": "boolean" },
            "pollSeconds": { "type": "integer", "minimum": 1 },
            "leaseSeconds": { "type": "integer", "minimum": 2 }
          }
        }
      }
    },
    "scheduler": {
      "type": "object",
      "properties": {
        "loop": { "type": "boolean" },
        "pollSeconds": { "type": "integer", "minimum": 1 }
      }
    },
    "evaluator": {
      "type": "object",
      "properties": {
        "pollSeconds": { "type": "integer", "minimum": 1 },
        "retentionDays": { "type": "integer", "minimum": 1 },
        "auditRetentionDays": { "type": "integer", "minimum": 1 },
        "retentionIntervalSeconds": { "type": "integer", "minimum": 60 },
        "sqlConnections": {
          "type": "object",
          "properties": {
            "existingSecret": { "type": "string" },
            "secretKey": { "type": "string", "minLength": 1 }
          },
          "required": ["existingSecret", "secretKey"]
        }
      }
    },
    "executionIsolation": {
      "type": "object",
      "properties": {
        "serviceAccountName": { "type": "string" },
        "runtimeClassName": { "type": "string" }
      }
    },
    "admissionPolicies": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "failurePolicy": {
          "type": "string",
          "enum": ["Fail", "Ignore"]
        },
        "security": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "validationActions": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["Deny", "Warn", "Audit"]
              },
              "minItems": 1
            }
          },
          "required": ["enabled", "validationActions"]
        },
        "images": {
          "type": "object",
          "properties": {
            "requireDigest": { "type": "boolean" },
            "enforceAllowed": { "type": "boolean" },
            "allowed": { "type": "array", "items": { "type": "string" } },
            "validationActions": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["Deny", "Warn", "Audit"]
              },
              "minItems": 1
            }
          },
          "required": ["requireDigest", "enforceAllowed", "allowed", "validationActions"]
        }
      },
      "required": ["enabled", "failurePolicy", "security", "images"]
    },
    "dashboard": {
      "type": "object",
      "properties": {
        "apiBaseUrl": { "type": "string" }
      }
    },
    "prometheusRules": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "labels": { "type": "object" },
        "queueOldestAgeSeconds": { "type": "integer", "minimum": 1 },
        "leaseAgeSeconds": { "type": "integer", "minimum": 1 },
        "poolSaturationRatio": { "type": "number", "minimum": 0, "maximum": 1 },
        "schedulerLagSeconds": { "type": "integer", "minimum": 1 },
        "workflowCriticalPathSeconds": { "type": "integer", "minimum": 1 },
        "apiErrorRateRatio": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "required": [
        "enabled",
        "labels",
        "queueOldestAgeSeconds",
        "leaseAgeSeconds",
        "poolSaturationRatio",
        "schedulerLagSeconds",
        "workflowCriticalPathSeconds",
        "apiErrorRateRatio"
      ]
    },
    "grafanaDashboards": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "labels": { "type": "object" }
      },
      "required": ["enabled", "labels"]
    },
    "config": {
      "type": "object",
      "properties": {
        "seedExamples": { "type": "boolean" },
        "databaseUrlSecret": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "key": { "type": "string", "minLength": 1 }
          }
        },
        "objectStorage": {
          "type": "object",
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["filesystem", "s3"]
            },
            "path": { "type": "string" },
            "bucket": { "type": "string", "minLength": 1 },
            "endpoint": { "type": "string" },
            "region": { "type": "string" },
            "pathStyle": { "type": "boolean" },
            "credentialsSecret": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "accessKeyKey": { "type": "string" },
                "secretKeyKey": { "type": "string" }
              }
            }
          }
        }
      }
    }
  },
  "required": ["image", "executionPools", "postgresql", "minio", "migrations"],
  "allOf": [
    {
      "if": {
        "properties": {
          "postgresql": {
            "properties": {
              "mode": { "const": "external" }
            }
          }
        }
      },
      "then": {
        "properties": {
          "config": {
            "properties": {
              "databaseUrlSecret": {
                "properties": {
                  "name": { "minLength": 1 }
                },
                "required": ["name"]
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "minio": {
            "properties": {
              "mode": { "const": "external" }
            }
          },
          "config": {
            "properties": {
              "objectStorage": {
                "properties": {
                  "mode": { "const": "s3" }
                }
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "config": {
            "properties": {
              "objectStorage": {
                "properties": {
                  "credentialsSecret": {
                    "properties": {
                      "name": { "minLength": 1 }
                    },
                    "required": ["name"]
                  }
                }
              }
            }
          }
        }
      }
    }
  ]
}
