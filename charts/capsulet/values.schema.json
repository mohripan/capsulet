{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "image": {
      "type": "object",
      "properties": {
        "registry": { "type": "string", "minLength": 1 },
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string", "minLength": 1 },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      },
      "required": ["registry", "repository", "tag", "pullPolicy"]
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" },
        "annotations": { "type": "object" }
      }
    },
    "rbac": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" }
      }
    },
    "executionPools": {
      "type": "object",
      "properties": {
        "defaultPool": { "type": "string", "minLength": 1 },
        "pools": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "object",
            "properties": {
              "description": { "type": "string" },
              "nodeSelector": { "type": "object" },
              "tolerations": { "type": "array" },
              "resources": { "type": "object" },
              "timeoutSeconds": { "type": "integer", "minimum": 1 },
              "maxConcurrentJobs": { "type": "integer", "minimum": 1 }
            },
            "required": ["resources", "timeoutSeconds", "maxConcurrentJobs"]
          }
        }
      },
      "required": ["defaultPool", "pools"]
    }
  },
  "required": ["image", "executionPools"]
}
