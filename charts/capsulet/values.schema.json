{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "image": {
      "type": "object",
      "properties": {
        "registry": { "type": "string" },
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string", "minLength": 1 },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      },
      "required": ["registry", "repository", "tag", "pullPolicy"]
    },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" },
        "annotations": { "type": "object" }
      }
    },
    "rbac": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" }
      }
    },
    "executionPools": {
      "type": "object",
      "properties": {
        "defaultPool": { "type": "string", "minLength": 1 },
        "pools": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "object",
            "properties": {
              "description": { "type": "string" },
              "nodeSelector": { "type": "object" },
              "tolerations": { "type": "array" },
              "resources": { "type": "object" },
              "timeoutSeconds": { "type": "integer", "minimum": 1 },
              "maxConcurrentJobs": { "type": "integer", "minimum": 1 },
              "ttlSecondsAfterFinished": { "type": "integer", "minimum": 0 }
            },
            "required": ["resources", "timeoutSeconds", "maxConcurrentJobs"]
          }
        }
      },
      "required": ["defaultPool", "pools"]
    },
    "postgresql": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["bundled", "external"]
        },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string", "minLength": 1 },
            "tag": { "type": "string", "minLength": 1 },
            "pullPolicy": {
              "type": "string",
              "enum": ["Always", "IfNotPresent", "Never"]
            }
          },
          "required": ["repository", "tag", "pullPolicy"]
        },
        "auth": {
          "type": "object",
          "properties": {
            "database": { "type": "string", "minLength": 1 },
            "username": { "type": "string", "minLength": 1 },
            "password": { "type": "string", "minLength": 1 }
          },
          "required": ["database", "username", "password"]
        },
        "service": {
          "type": "object",
          "properties": {
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
          },
          "required": ["port"]
        },
        "persistence": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "size": { "type": "string", "minLength": 1 },
            "storageClass": { "type": "string" }
          },
          "required": ["enabled", "size"]
        },
        "securityContext": { "type": "object" },
        "containerSecurityContext": { "type": "object" },
        "resources": { "type": "object" }
      },
      "required": ["mode", "image", "auth", "service", "persistence"]
    },
    "minio": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["bundled", "external"]
        },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string", "minLength": 1 },
            "tag": { "type": "string", "minLength": 1 },
            "pullPolicy": {
              "type": "string",
              "enum": ["Always", "IfNotPresent", "Never"]
            }
          },
          "required": ["repository", "tag", "pullPolicy"]
        },
        "mcImage": {
          "type": "object",
          "properties": {
            "repository": { "type": "string", "minLength": 1 },
            "tag": { "type": "string", "minLength": 1 },
            "pullPolicy": {
              "type": "string",
              "enum": ["Always", "IfNotPresent", "Never"]
            }
          },
          "required": ["repository", "tag", "pullPolicy"]
        },
        "auth": {
          "type": "object",
          "properties": {
            "rootUser": { "type": "string", "minLength": 1 },
            "rootPassword": { "type": "string", "minLength": 8 }
          },
          "required": ["rootUser", "rootPassword"]
        },
        "bucket": { "type": "string", "minLength": 1 },
        "region": { "type": "string", "minLength": 1 },
        "pathStyle": { "type": "boolean" },
        "service": {
          "type": "object",
          "properties": {
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
            "consolePort": { "type": "integer", "minimum": 1, "maximum": 65535 }
          },
          "required": ["port", "consolePort"]
        },
        "persistence": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "size": { "type": "string", "minLength": 1 },
            "storageClass": { "type": "string" }
          },
          "required": ["enabled", "size"]
        },
        "securityContext": { "type": "object" },
        "containerSecurityContext": { "type": "object" },
        "resources": { "type": "object" },
        "bucketJob": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "backoffLimit": { "type": "integer", "minimum": 0 }
          },
          "required": ["enabled", "backoffLimit"]
        }
      },
      "required": ["mode", "image", "mcImage", "auth", "bucket", "region", "pathStyle", "service", "persistence", "bucketJob"]
    },
    "migrations": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "backoffLimit": { "type": "integer", "minimum": 0 }
      },
      "required": ["enabled", "backoffLimit"]
    },
    "worker": {
      "type": "object",
      "properties": {
        "runner": {
          "type": "object",
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["stub", "kubernetes", "k8s"]
            },
            "executionNamespace": { "type": "string" },
            "logLimitBytes": { "type": "integer", "minimum": 1 },
            "loop": { "type": "boolean" },
            "pollSeconds": { "type": "integer", "minimum": 1 },
            "leaseSeconds": { "type": "integer", "minimum": 2 }
          }
        }
      }
    },
    "scheduler": {
      "type": "object",
      "properties": {
        "loop": { "type": "boolean" },
        "pollSeconds": { "type": "integer", "minimum": 1 }
      }
    },
    "dashboard": {
      "type": "object",
      "properties": {
        "apiBaseUrl": { "type": "string" }
      }
    },
    "config": {
      "type": "object",
      "properties": {
        "seedExamples": { "type": "boolean" },
        "databaseUrlSecret": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "key": { "type": "string", "minLength": 1 }
          }
        },
        "objectStorage": {
          "type": "object",
          "properties": {
            "mode": {
              "type": "string",
              "enum": ["filesystem", "s3"]
            },
            "path": { "type": "string" },
            "bucket": { "type": "string", "minLength": 1 },
            "endpoint": { "type": "string" },
            "region": { "type": "string" },
            "pathStyle": { "type": "boolean" },
            "credentialsSecret": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "accessKeyKey": { "type": "string" },
                "secretKeyKey": { "type": "string" }
              }
            }
          }
        }
      }
    }
  },
  "required": ["image", "executionPools", "postgresql", "minio", "migrations"],
  "allOf": [
    {
      "if": {
        "properties": {
          "postgresql": {
            "properties": {
              "mode": { "const": "external" }
            }
          }
        }
      },
      "then": {
        "properties": {
          "config": {
            "properties": {
              "databaseUrlSecret": {
                "properties": {
                  "name": { "minLength": 1 }
                },
                "required": ["name"]
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "minio": {
            "properties": {
              "mode": { "const": "external" }
            }
          },
          "config": {
            "properties": {
              "objectStorage": {
                "properties": {
                  "mode": { "const": "s3" }
                }
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "config": {
            "properties": {
              "objectStorage": {
                "properties": {
                  "credentialsSecret": {
                    "properties": {
                      "name": { "minLength": 1 }
                    },
                    "required": ["name"]
                  }
                }
              }
            }
          }
        }
      }
    }
  ]
}
