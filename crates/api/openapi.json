{
  "openapi": "3.1.0",
  "info": {
    "title": "Capsulet API",
    "version": "0.1.0",
    "description": "Control-plane API for typed agent execution graphs, memory graph primitives, agents, agent runs, jobs, compatibility workflow DAGs, automations, logs, artifacts, audit, and health."
  },
  "servers": [
    { "url": "http://127.0.0.1:8080" }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "service-token or OIDC JWT"
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" }
        }
      }
    }
  },
  "security": [{ "bearerAuth": [] }],
  "paths": {
    "/livez": { "get": { "security": [], "summary": "Liveness check", "responses": { "200": { "description": "Process is alive" } } } },
    "/readyz": { "get": { "security": [], "summary": "Readiness check", "responses": { "200": { "description": "Database is reachable" }, "503": { "description": "Not ready" } } } },
    "/healthz": { "get": { "security": [], "summary": "Health check alias", "responses": { "200": { "description": "Healthy" }, "503": { "description": "Unhealthy" } } } },
    "/metrics": { "get": { "security": [], "summary": "Prometheus metrics", "responses": { "200": { "description": "Metrics text" } } } },
    "/openapi.json": { "get": { "security": [], "summary": "OpenAPI description", "responses": { "200": { "description": "OpenAPI JSON" } } } },
    "/v1/auth/me": { "get": { "summary": "Current principal", "responses": { "200": { "description": "Authenticated identity with role, platform admin flag, scopes, and project memberships" }, "401": { "description": "Authentication required" } } } },
    "/v1/projects": { "get": { "summary": "List visible projects", "responses": { "200": { "description": "Projects visible to the current principal" }, "401": { "description": "Authentication required" } } } },
    "/v1/projects/{project_id}/memberships": { "get": { "summary": "List project memberships", "responses": { "200": { "description": "Project memberships visible to a project admin" }, "403": { "description": "Project admin role required" } } }, "post": { "summary": "Create or update a project membership", "responses": { "200": { "description": "Project membership saved" }, "400": { "description": "Invalid membership" }, "403": { "description": "Project admin role required" } } } },
    "/v1/projects/{project_id}/memberships/{principal_kind}/{principal_name}": { "delete": { "summary": "Delete a project membership", "responses": { "204": { "description": "Deleted" }, "403": { "description": "Project admin role required" } } } },
    "/v1/service-accounts": { "get": { "summary": "List database-backed service accounts", "responses": { "200": { "description": "Service accounts" }, "403": { "description": "Admin permission required" } } }, "post": { "summary": "Create a database-backed service account and return its one-time token", "responses": { "201": { "description": "Created with one-time token" }, "400": { "description": "Validation error" }, "403": { "description": "Admin permission required" } } } },
    "/v1/service-accounts/{id}/revoke": { "post": { "summary": "Revoke a service account token", "responses": { "204": { "description": "Revoked" }, "400": { "description": "Unknown service account" }, "403": { "description": "Admin permission required" } } } },
    "/v1/audit-events": { "get": { "summary": "List audit events", "responses": { "200": { "description": "Audit events" }, "403": { "description": "Admin permission required" } } } },
    "/v1/job-definitions": { "get": { "summary": "List job definitions", "responses": { "200": { "description": "Definitions" } } }, "post": { "summary": "Create job definition", "responses": { "201": { "description": "Created" }, "400": { "description": "Validation error" } } } },
    "/v1/job-definitions/{id}": { "get": { "summary": "Get job definition", "responses": { "200": { "description": "Definition" }, "404": { "description": "Not found" } } }, "put": { "summary": "Replace job definition", "responses": { "200": { "description": "Updated" }, "409": { "description": "Locked by active workflow run" } } }, "delete": { "summary": "Delete job definition", "responses": { "204": { "description": "Deleted" }, "404": { "description": "Not found" }, "409": { "description": "Referenced by active workflow run" } } } },
    "/v1/graphs": { "get": { "summary": "List typed agent execution graphs", "responses": { "200": { "description": "Graphs" } } }, "post": { "summary": "Create typed agent execution graph", "responses": { "201": { "description": "Created" }, "400": { "description": "Invalid graph" } } } },
    "/v1/graphs/{id}": { "get": { "summary": "Get typed agent execution graph", "responses": { "200": { "description": "Graph" }, "404": { "description": "Not found" } } } },
    "/v1/memory/sources": { "get": { "summary": "List memory sources", "responses": { "200": { "description": "Sources" } } }, "post": { "summary": "Create memory source", "responses": { "201": { "description": "Created" }, "400": { "description": "Validation error" } } } },
    "/v1/memory/sources/{id}": { "get": { "summary": "Get memory source", "responses": { "200": { "description": "Source" }, "404": { "description": "Not found" } } } },
    "/v1/memory/evidence": { "get": { "summary": "List evidence records", "responses": { "200": { "description": "Evidence" } } }, "post": { "summary": "Create evidence record", "responses": { "201": { "description": "Created" }, "400": { "description": "Validation error" } } } },
    "/v1/memory/evidence/{id}": { "get": { "summary": "Get evidence record", "responses": { "200": { "description": "Evidence" }, "404": { "description": "Not found" } } } },
    "/v1/memory/entities": { "get": { "summary": "List memory entities", "responses": { "200": { "description": "Entities" } } }, "post": { "summary": "Create memory entity", "responses": { "201": { "description": "Created" }, "400": { "description": "Validation error" } } } },
    "/v1/memory/entities/{id}": { "get": { "summary": "Get memory entity", "responses": { "200": { "description": "Entity" }, "404": { "description": "Not found" } } } },
    "/v1/memory/claims": { "get": { "summary": "List memory claims", "responses": { "200": { "description": "Claims" } } }, "post": { "summary": "Create evidence-backed claim", "responses": { "201": { "description": "Created" }, "400": { "description": "Validation error" } } } },
    "/v1/memory/claims/{id}": { "get": { "summary": "Get memory claim", "responses": { "200": { "description": "Claim" }, "404": { "description": "Not found" } } } },
    "/v1/memory/events": { "get": { "summary": "List memory events", "responses": { "200": { "description": "Events" } } }, "post": { "summary": "Create evidence-backed event", "responses": { "201": { "description": "Created" }, "400": { "description": "Validation error" } } } },
    "/v1/memory/events/{id}": { "get": { "summary": "Get memory event", "responses": { "200": { "description": "Event" }, "404": { "description": "Not found" } } } },
    "/v1/memory/relationships": { "get": { "summary": "List memory relationships", "responses": { "200": { "description": "Relationships" } } }, "post": { "summary": "Create evidence-backed relationship", "responses": { "201": { "description": "Created" }, "400": { "description": "Validation error" } } } },
    "/v1/memory/relationships/{id}": { "get": { "summary": "Get memory relationship", "responses": { "200": { "description": "Relationship" }, "404": { "description": "Not found" } } } },
    "/v1/memory/contracts": { "get": { "summary": "List memory contract DSL documents", "responses": { "200": { "description": "Memory contracts" } } }, "post": { "summary": "Create memory contract from DSL", "responses": { "201": { "description": "Created with compiled policy summary" }, "400": { "description": "DSL parse or validation error" } } } },
    "/v1/memory/contracts/{id}": { "get": { "summary": "Get memory contract", "responses": { "200": { "description": "Memory contract with compiled policy summary" }, "404": { "description": "Not found" } } } },
    "/v1/agents": { "get": { "summary": "List agent definitions", "responses": { "200": { "description": "Agents" } } }, "post": { "summary": "Create agent definition", "responses": { "201": { "description": "Created" }, "400": { "description": "Validation error" }, "404": { "description": "Graph not found" } } } },
    "/v1/agents/{id}": { "get": { "summary": "Get agent definition", "responses": { "200": { "description": "Agent" }, "404": { "description": "Not found" } } } },
    "/v1/agents/{id}/runs": { "post": { "summary": "Start agent run", "responses": { "201": { "description": "Queued agent run" }, "404": { "description": "Agent not found" } } } },
    "/v1/agent-runs": { "get": { "summary": "List agent runs", "responses": { "200": { "description": "Agent runs" } } } },
    "/v1/agent-runs/{id}": { "get": { "summary": "Get agent run", "responses": { "200": { "description": "Agent run current state" }, "404": { "description": "Not found" } } } },
    "/v1/workflows": { "get": { "summary": "List compatibility workflows", "responses": { "200": { "description": "Workflows" } } }, "post": { "summary": "Create compatibility workflow DAG", "responses": { "201": { "description": "Created" }, "400": { "description": "Invalid DAG" } } } },
    "/v1/workflows/{id}": { "get": { "summary": "Get workflow", "responses": { "200": { "description": "Workflow" }, "404": { "description": "Not found" } } }, "put": { "summary": "Replace workflow", "responses": { "200": { "description": "Updated" }, "409": { "description": "Locked by active run" } } }, "delete": { "summary": "Delete workflow", "responses": { "204": { "description": "Deleted" }, "404": { "description": "Not found" }, "409": { "description": "Referenced by active run or automation" } } } },
    "/v1/automations": { "get": { "summary": "List automations", "responses": { "200": { "description": "Automations" } } }, "post": { "summary": "Create automation", "responses": { "201": { "description": "Created" } } } },
    "/v1/automations/{id}": { "get": { "summary": "Get automation", "responses": { "200": { "description": "Automation" }, "404": { "description": "Not found" } } }, "put": { "summary": "Replace automation", "responses": { "200": { "description": "Updated" } } }, "delete": { "summary": "Delete automation", "responses": { "204": { "description": "Deleted" } } } },
    "/v1/automations/{id}/enable": { "post": { "summary": "Enable automation", "responses": { "200": { "description": "Enabled" } } } },
    "/v1/automations/{id}/disable": { "post": { "summary": "Disable automation", "responses": { "200": { "description": "Disabled" } } } },
    "/v1/automations/{id}/trigger": { "post": { "summary": "Manually trigger automation", "responses": { "201": { "description": "Workflow run created" } } } },
    "/v1/workflow-runs": { "get": { "summary": "List workflow runs", "responses": { "200": { "description": "Workflow runs with step runs" } } } },
    "/v1/events/stream": { "get": { "summary": "Stream dashboard activity changes with server-sent events", "responses": { "200": { "description": "SSE stream of compact activity snapshots", "content": { "text/event-stream": { "schema": { "type": "string" } } } } } } },
    "/v1/workflow-runs/{id}": { "get": { "summary": "Get workflow run detail", "responses": { "200": { "description": "Workflow run with step history and job links" }, "404": { "description": "Not found" } } } },
    "/v1/workflow-runs/{id}/logs": { "get": { "summary": "Get aggregate workflow logs", "responses": { "200": { "description": "Step/job logs" } } } },
    "/v1/workflow-runs/{id}/logs/stream": { "get": { "summary": "Stream aggregate workflow logs with server-sent events", "responses": { "200": { "description": "SSE stream of snapshot, done, and error events", "content": { "text/event-stream": { "schema": { "type": "string" } } } } } } },
    "/v1/workflow-runs/{id}/remove": { "post": { "summary": "Remove queued workflow run", "responses": { "200": { "description": "Removed" } } } },
    "/v1/workflow-runs/{id}/cancel": { "post": { "summary": "Cancel workflow run", "responses": { "200": { "description": "Cancelled" } } } },
    "/v1/workflow-runs/{id}/resume": { "post": { "summary": "Manual re-run from successful checkpoints", "responses": { "200": { "description": "Resumed" } } } },
    "/v1/jobs/runs": { "get": { "summary": "List job runs", "responses": { "200": { "description": "Runs" } } }, "post": { "summary": "Create job run", "responses": { "201": { "description": "Created" } } } },
    "/v1/jobs/runs/{id}": { "get": { "summary": "Get job run", "responses": { "200": { "description": "Run" }, "404": { "description": "Not found" } } } },
    "/v1/jobs/runs/{id}/logs": { "get": { "summary": "Get job logs", "responses": { "200": { "description": "Logs" } } } },
    "/v1/jobs/runs/{id}/logs/stream": { "get": { "summary": "Stream job logs with server-sent events", "responses": { "200": { "description": "SSE stream of snapshot, done, and error events", "content": { "text/event-stream": { "schema": { "type": "string" } } } } } } },
    "/v1/jobs/runs/{id}/cancel": { "post": { "summary": "Cancel job run", "responses": { "200": { "description": "Cancelled" } } } },
    "/v1/jobs/runs/{id}/artifacts": { "get": { "summary": "List artifacts", "responses": { "200": { "description": "Artifacts" } } } },
    "/v1/jobs/runs/{id}/artifacts/{artifact_id}": { "get": { "summary": "Download artifact", "responses": { "200": { "description": "Artifact bytes" }, "404": { "description": "Not found" } } } }
  }
}
